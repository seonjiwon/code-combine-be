<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <property name="LOG_PATTERN"
    value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>
  <property name="LOG_PATH" value="/app/logs"/>

  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>${LOG_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <!-- 현재 기록 중인 파일 경로 -->
    <file>${LOG_PATH}/code-combine.log</file>
    <encoder>
      <pattern>${LOG_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <!-- 롤링된 파일 이름 패턴: 날짜별로 새 파일 생성 -->
      <fileNamePattern>${LOG_PATH}/code-combine.%d{yyyy-MM-dd}.log</fileNamePattern>
      <!--
          maxHistory: 최대 보관 파일 수 (일 단위 롤링이므로 365 = 365일)
          넉넉하게 잡은 이유: 실질적 삭제는 totalSizeCap이 담당하도록 의도
          maxHistory를 14로 잡으면 용량 여유가 있어도 14일 지나면 삭제되므로,
          용량 기반 삭제 정책과 충돌할 수 있음
      -->
      <maxHistory>365</maxHistory>
      <!--
          totalSizeCap: 전체 로그 파일 합계 상한 (1GB)
          EC2 t2.micro 30GB EBS 중 현재 27GB 여유 → 1GB는 충분히 안전한 범위
          이 상한을 초과하면 가장 오래된 파일부터 자동 삭제
      -->
      <totalSizeCap>1GB</totalSizeCap>
      <!--
          오래된 로그 파일을 정리. 컨테이너 재시작 후에도 정책이 즉시 적용되도록 보장
      -->
      <cleanHistoryOnStart>true</cleanHistoryOnStart>
    </rollingPolicy>
  </appender>

  <!-- INFO + 콘솔 + 파일 -->
  <springProfile name="!dev">
    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
      <appender-ref ref="FILE"/>
    </root>
    <!--
        Spring/Hibernate 내부 로그는 WARN 이상만 기록
    -->
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.hibernate" level="WARN"/>
  </springProfile>

</configuration>